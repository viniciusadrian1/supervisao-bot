# ====================================================================
# Supervisão 360 — Bot de WhatsApp (UAZAPI)
# Copie para .env e preencha. NÃO comite o .env.
# ====================================================================

# Porta local. No Render a porta vem da env PORT automaticamente.
PORT=3000

# URL pública do bot (Render te dá uma, ex.: https://supervisao-bot.onrender.com).
# Usada para (1) registrar o webhook na UAZAPI e (2) servir o vídeo demo.
PUBLIC_URL=

# Provedor de WhatsApp (uazapi | mock). mock = teste local sem enviar nada.
PROVIDER=uazapi

# ---- UAZAPI ----
# Subdomínio do SEU servidor uazapi (veja no painel; ex.: free, api, focus...).
UAZAPI_BASE_URL=https://free.uazapi.com
# Token da INSTÂNCIA (gerado ao criar a instância / no painel).
UAZAPI_TOKEN=
# (Opcional) Token ADMIN — só para scripts de criar instância / webhook global.
UAZAPI_ADMIN_TOKEN=

# ---- IA (OpenAI) — OPCIONAL ----
# Liga a "inteligência" do bot: entende objeções/respostas ditas de qualquer jeito.
# A IA SÓ classifica/extrai — as respostas continuam saindo do roteiro fixo (zero
# alucinação). SEM chave, o bot funciona normalmente nas regras determinísticas.
OPENAI_API_KEY=
# Modelo. Padrão gpt-4o-mini (barato, disponível em qualquer conta). Recomendado
# atual: gpt-5.4-nano (mais novo/barato) ou gpt-5.4-mini (mais preciso).
OPENAI_MODEL=gpt-4o-mini
# Só usado por modelos GPT-5.x / série o (gpt-4o-mini ignora): none | low | medium | high
OPENAI_REASONING_EFFORT=low
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_MS=8000

# Segredo no caminho do webhook (ex.: a8f3c...). O webhook fica em /webhook/SEU_SEGREDO.
# Local: opcional (vazio = /webhook simples, só avisa). PRODUÇÃO (NODE_ENV=production):
# OBRIGATÓRIO — vazio faz o app NÃO subir (por design, pra não deixar o webhook público).
# No Render, o render.yaml já gera este valor automaticamente (generateValue).
WEBHOOK_SECRET=

# ---- Vídeo demonstrativo ----
# Por padrão é servido pelo próprio bot em PUBLIC_URL/media/demo.mp4.
# Se quiser hospedar em outro lugar (CDN / link .mp4 direto), cole a URL aqui:
VIDEO_URL=
VIDEO_FILE=demo.mp4

# (Opcional) Número que recebe um AVISO a cada lead qualificado (DDI+DDD, só dígitos).
# Deixe vazio se o atendimento é no mesmo número (o humano já vê a conversa).
OWNER_NUMBER=

# Site exibido na mensagem final
SITE_URL=supervisao.com.br

# ---- Reengajamento por inatividade ----
IDLE_ENABLED=true
IDLE_MINUTES=30

# ---- Persistência ----
# No Render, aponte para o disco persistente (ex.: /data). Local: ./data
DATA_DIR=./data

# ---- Humanização (anti-ban): duração do "digitando..." ----
TYPING_MIN_MS=900
TYPING_MAX_MS=3500
TYPING_PER_CHAR_MS=35

# Palavra para REATIVAR o bot num contato que já passou para atendimento humano.
RESUME_KEYWORD=#bot

# ---- Painel de visualização (read-only) em /painel ----
# Sem PANEL_PASSWORD o painel fica DESLIGADO. Com senha, acesse PUBLIC_URL/painel
# (login pelo navegador). Mostra fluxo, copy, funil de conversão e leads ao vivo.
PANEL_USER=admin
PANEL_PASSWORD=
